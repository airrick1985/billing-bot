# 複製為 .env.local 後填入實際值(.env.local 不會進版控)

# Google OAuth 用戶端 ID(SETUP.md 步驟一)
VITE_GOOGLE_CLIENT_ID=

# 系統主檔試算表 ID(初次登入建立後,從管理後台「系統資訊」複製)
VITE_MASTER_SHEET_ID=

# OCR Proxy 位址;部署到 Vercel 時填 /api/ocr(本機開發留空 = 前端直連,需在設定頁輸 Key)
VITE_OCR_PROXY_URL=

# ---- 以下為 Vercel 伺服器端變數(OCR Proxy 用,不會進前端 bundle)----
# GOOGLE_CLIENT_ID=      同 VITE_GOOGLE_CLIENT_ID
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
